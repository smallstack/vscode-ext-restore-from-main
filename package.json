{
	"name": "restore-from-main",
	"displayName": "Restore from Main",
	"description": "Restore files from main branch",
	"publisher": "smallstack",
	"repository": {
		"type": "git",
		"url": "https://github.com/smallstack/vscode-ext-restore-from-main.git"
	},
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.75.0"
	},
	"activationEvents": [
		"onCommand:restore-from-main.restoreFromMain"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "restore-from-main.restoreFromMain",
				"title": "Restore from Main"
			}
		],
		"menus": {
			"explorer/context": [
				{
					"command": "restore-from-main.restoreFromMain",
					"group": "2_workspace",
					"when": "!explorerResourceIsFolder"
				}
			]
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./"
	},
	"devDependencies": {
		"@types/vscode": "^1.60.0",
		"@types/node": "^14.0.0",
		"typescript": "^5"
	}
}
